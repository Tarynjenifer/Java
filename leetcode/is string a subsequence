class Solution {
    public boolean isSubsequence(String s, String t) {
        int flag=0;
        for(int i=0;i<s.length();i++){
            if(t.contains(String.valueOf(s.charAt(i)))){
                flag++;
            }   
        }if(flag==s.length()){
            return true;
        }return false;
    }
}
