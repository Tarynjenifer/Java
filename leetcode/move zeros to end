class Solution {
    public void moveZeroes(int[] nums) {
        ArrayList<Integer>li=new ArrayList<>();
		int count=0;
		for(int i=0;i<nums.length;i++){
			if(nums[i]==0){
				count++;
				continue;
			}li.add(nums[i]);
		}for(int i=0;i<count;i++){
			li.add(0);
		}for(int i=0;i<nums.length;i++){
            nums[i]=li.get(i);
        }	
    }
}
