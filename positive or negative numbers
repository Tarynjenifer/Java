import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner in=new Scanner(System.in);
		int n=in.nextInt();
		if(n==0){
			System.out.println("zero");
		}
		else if(n>0){
			System.out.println("positive number");
		}else if(n<0){
			System.out.println("negative number");
		}
	}
}
